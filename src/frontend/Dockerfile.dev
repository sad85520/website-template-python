# Dev image：僅供 docker-compose.yml（非 prod overlay）使用。
# 與 prod Dockerfile 的差異：
#   - 不 COPY 程式碼：compose 以 `./src/frontend:/app` + 具名 volume
#     `frontend-node-modules:/app/node_modules` 覆寫，讓 Vite dev server
#     能即時 HMR；`node_modules` 用具名 volume 避免 host 的 node_modules
#     覆寫到容器內已裝好的依賴。
#   - 跑 Vite dev server (port 5173)，不走 nginx。
# 如需 prod image（多階段 build + nginx.spa.conf），請用 src/frontend/Dockerfile。
FROM node:26-alpine

WORKDIR /app

RUN npm install -g pnpm

COPY package.json pnpm-lock.yaml ./
RUN pnpm install

EXPOSE 5173

CMD ["pnpm", "dev"]
