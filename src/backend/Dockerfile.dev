# Dev image：僅供 docker-compose.yml（非 prod overlay）使用。
# 與 prod Dockerfile 的差異：
#   - 不建 app 程式碼進 image：compose 以 `./src/backend:/app` bind-mount
#     蓋上來，讓編輯器改 .py 檔後 Django runserver 能即時 reload。
#   - 不建立 non-root user：dev 方便性優先，檔案權限直接沿用 host。
#   - 使用 `python manage.py runserver`，不走 gunicorn。
# 如需 prod image（non-root + gunicorn + collectstatic），請用 src/backend/Dockerfile。
#
# Base image 固定到 `-slim-bookworm`，對齊 prod Dockerfile 的 Debian 版本，避免
# `python:3.12-slim` 隨官方升基底版本後 dev / prod 出現 glibc 或系統套件差異。
# 若要更嚴格，請改為完整 digest（`python:3.12-slim-bookworm@sha256:...`），
# 並用 Dependabot/Renovate 自動 PR 升級。
FROM python:3.12-slim-bookworm

# uv 版本對齊 prod Dockerfile；用 `latest` 會讓 dev 與 CI / prod 可能跑到不同
# resolver 行為（uv.lock 格式、解析策略都有過 breaking change），統一 pin 住。
COPY --from=ghcr.io/astral-sh/uv:0.5.11 /uv /uvx /bin/

WORKDIR /app

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    DJANGO_SETTINGS_MODULE=config.settings.development \
    PATH="/app/.venv/bin:$PATH"

# 只安裝依賴，不 COPY 程式碼——程式碼由 compose bind mount 進來。
COPY pyproject.toml uv.lock ./
RUN uv sync --frozen

EXPOSE 8000

CMD ["python", "manage.py", "runserver", "0.0.0.0:8000"]
