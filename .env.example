# Docker Compose 環境變數範本
# 複製此檔案為 .env 並填入實際值

# Database (PostgreSQL)
# 將 <REPLACE_ME> 改為你「個人產生」的強密碼，不要沿用文件範例或 Slack 群組共用值；
# 文件內的固定字串被多人複製後等同於「已知 key」，攻擊者掃到 repo 即可嘗試登入。
# 簡易產法：
#   openssl rand -hex 24
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
DB_NAME=website_template
DB_USER=postgres
DB_PASSWORD=<REPLACE_ME>
DB_HOST=postgres
DB_PORT=5432

# Django
# SECRET_KEY 供 session/CSRF/signing 用，洩漏等同整站被接管；勿沿用範例值。
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=<REPLACE_ME_DJANGO_SECRET_KEY>
DJANGO_SETTINGS_MODULE=config.settings.development
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# JWT
# 必須 ≥ 32 字元（256-bit）；同樣由個人產生。
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SIGNING_KEY=<REPLACE_ME_MIN_32_CHARS>
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
