# Docker Compose 環境變數範本
# 複製此檔案為 .env 並填入實際值

# Database (PostgreSQL)
DB_NAME=website_template
DB_USER=postgres
DB_PASSWORD=YourStrong!Passw0rd
DB_HOST=postgres
DB_PORT=5432

# Django
SECRET_KEY=your-django-secret-key-here-must-be-long-and-random
DJANGO_SETTINGS_MODULE=config.settings.development
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# JWT
JWT_SIGNING_KEY=your-256-bit-jwt-signing-key-at-least-32-chars
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
